---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteContent } from "../data/siteContent";
---

<BaseLayout title={`${siteContent.brand.name} - Impressum`} description={`Impressum und Kontaktangaben von ${siteContent.brand.name}.`}>
  <main id="main-content" class="min-h-screen bg-white px-5 py-32 text-[var(--dw-ink)] md:py-40">
    <section class="mx-auto max-w-[820px]">
      <p class="font-utility text-xs font-bold uppercase tracking-[0.12em] text-[var(--dw-accent-strong)]">Rechtliches</p>
      <h1 class="mt-5 font-display text-5xl font-black leading-tight tracking-[-0.025em] text-[var(--dw-ink)]">Impressum</h1>
      <div class="mt-8 rounded-lg border border-[var(--dw-card-border)] bg-[var(--dw-surface-warm)] p-6 text-sm font-medium leading-7 text-[var(--dw-ink-soft)]">
        <h2 class="font-impact text-lg font-black text-[var(--dw-ink)]">Angaben nach Paragraf 5 DDG</h2>
        <p class="mt-4">{siteContent.brand.name}</p>
        <p>{siteContent.brand.addressLine}</p>

        <h2 class="mt-8 font-impact text-lg font-black text-[var(--dw-ink)]">Kontakt</h2>
        <p class="mt-4">
          E-Mail: <a class="inline-flex min-h-11 items-center font-black text-[var(--dw-accent-strong)]" href={`mailto:${siteContent.brand.email}`}>{siteContent.brand.email}</a>
        </p>

        <h2 class="mt-8 font-impact text-lg font-black text-[var(--dw-ink)]">Verantwortlich für den Inhalt</h2>
        <p class="mt-4">{siteContent.brand.name}</p>

        <h2 class="mt-8 font-impact text-lg font-black text-[var(--dw-ink)]">Hinweis</h2>
        <p class="mt-4">
          Diese Angaben bilden die im Projekt hinterlegten Kontakt- und Anbieterinformationen ab. Vor einer produktiven
          Veröffentlichung sollten Rechtsform, vertretungsberechtigte Person, vollständige ladungsfähige Anschrift,
          Umsatzsteuer-ID und weitere branchenspezifische Pflichtangaben fachlich geprüft und ergänzt werden.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
