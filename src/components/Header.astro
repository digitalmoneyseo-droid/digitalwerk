---
import Icon from "./Icon.astro";
import { siteContent } from "../data/siteContent";
import { normalizePath } from "../lib/pageContent";
import type { NavGroup } from "../lib/navigation";

const navTone = {
  shell: "border-[oklch(0.88_0.018_250)] bg-white/90 text-[oklch(0.22_0.035_260)] shadow-[0_12px_40px_oklch(0.2_0.035_250/0.1)] backdrop-blur-xl",
  brand: "bg-[oklch(0.14_0.025_260)] text-white shadow-[0_8px_18px_oklch(0.18_0.03_260/0.14)]",
  link: "text-[oklch(0.36_0.035_260)] hover:bg-[oklch(0.94_0.024_245)] hover:text-[oklch(0.17_0.03_260)]",
  active: "bg-[oklch(0.9_0.04_245)] text-[oklch(0.34_0.12_245)]",
  panel: "border-[oklch(0.88_0.018_250)] bg-white text-[oklch(0.18_0.025_260)] shadow-[0_18px_54px_oklch(0.2_0.035_250/0.14)]",
  button: "bg-[oklch(0.14_0.025_260)] text-white hover:bg-[oklch(0.28_0.08_250)]",
};

const navGroups: NavGroup[] = [
  {
    key: "services",
    label: siteContent.navigation.servicesLabel,
    items: [
      {
        label: "Webdesign",
        href: "/leistungen/webdesign",
        description: "Individuelle Websites, die Besucher in Kunden verwandeln",
        icon: "Monitor",
        iconBg: "bg-[oklch(0.9_0.075_260)]",
        iconText: "text-[oklch(0.48_0.17_250)]",
      },
      {
        label: "SEO",
        href: "/leistungen/local-seo",
        description: "Besser bei Google ranken und organischen Traffic steigern",
        icon: "Search",
        iconBg: "bg-[oklch(0.9_0.11_150)]",
        iconText: "text-[oklch(0.56_0.18_150)]",
      },
      {
        label: "Paid Ads",
        href: "/leistungen/paid-ads",
        description: "Werbekampagnen über Google, Meta und weitere Kanäle",
        icon: "Megaphone",
        iconBg: "bg-[oklch(0.91_0.085_84)]",
        iconText: "text-[oklch(0.63_0.16_72)]",
      },
      {
        label: "KI-Lösungen",
        href: "/leistungen/geo",
        description: "Mit intelligenten KI-Tools automatisieren und skalieren",
        icon: "Sparkles",
        iconBg: "bg-[oklch(0.91_0.08_300)]",
        iconText: "text-[oklch(0.58_0.21_300)]",
      },
      {
        label: "1:1 Website-Hilfe",
        href: "/leistungen/website-hilfe",
        description: "Live-Screen-Sharing-Sessions mit einem echten Webdesigner",
        icon: "Video",
        iconBg: "bg-[oklch(0.92_0.105_95)]",
        iconText: "text-[oklch(0.64_0.17_70)]",
      },
    ],
  },
  {
    key: "work",
    label: siteContent.navigation.workLabel,
    items: [
      {
        label: "Projektarten",
        href: "/cases",
        description: "Relaunches, SEO-Strukturen und Landingpages als Startpunkte",
        icon: "BriefcaseBusiness",
        iconBg: "bg-[oklch(0.94_0.04_245)]",
        iconText: "text-[oklch(0.42_0.12_245)]",
      },
      {
        label: "Methode",
        href: "/methode",
        description: "Erstberatung, Empfehlung und Umsetzung ohne Umwege",
        icon: "Target",
        iconBg: "bg-[oklch(0.94_0.04_245)]",
        iconText: "text-[oklch(0.42_0.12_245)]",
      },
    ],
  },
];

const topLinks = [
  ["Über uns", "/agentur"],
  ["Preise", "/preise"],
  ["Enterprise", "/enterprise"],
] as const;

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => (href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(`${href}/`));
const isGroupActive = (group: NavGroup) => group.items.some((item) => isActive(item.href));
---

<header class="fixed left-0 right-0 top-0 z-50 px-3 pt-3 sm:px-5" data-nav-root>
  <div class={`mx-auto max-w-[1180px] rounded-[28px] border px-3 py-2 ${navTone.shell}`}>
    <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3">
      <a
        href="/"
        aria-current={isActive("/") ? "page" : undefined}
        class="flex min-w-0 items-center gap-2 rounded-full pr-2 outline-none transition-transform hover:translate-x-0.5 active:scale-[0.98]"
      >
        <span class={`grid h-8 w-8 shrink-0 place-items-center rounded-full font-impact text-xs font-black leading-none ${navTone.brand}`}>D</span>
        <span class="block truncate font-impact text-base font-extrabold leading-[1.25]">{siteContent.brand.name}</span>
      </a>

      <nav class="hidden items-center justify-center gap-1 lg:flex" aria-label="Hauptnavigation">
        <a href="/agentur" aria-current={isActive("/agentur") ? "page" : undefined} class={`inline-flex min-h-10 items-center rounded-full px-3.5 py-2 text-[13px] font-extrabold leading-[1.35] transition active:scale-[0.97] ${navTone.link} ${isActive("/agentur") ? navTone.active : ""}`}>
          Über uns
        </a>
        {
          navGroups.map((group) => (
            <div class="dw-desktop-menu relative">
              <button
                type="button"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls={`${group.key}-menu`}
                data-menu-trigger
                class={`relative flex min-h-10 items-center gap-1 rounded-full px-3.5 py-2 text-[13px] font-extrabold leading-[1.35] transition active:scale-[0.97] ${navTone.link} ${isGroupActive(group) ? navTone.active : ""}`}
              >
                {group.label}
                <span data-menu-chevron class="grid transition-transform">
                  <Icon name="ChevronDown" size={15} />
                </span>
              </button>
              <div
                id={`${group.key}-menu`}
                data-menu-panel
                class={`dw-menu-panel pointer-events-none invisible absolute left-1/2 top-full pt-3 opacity-0 transition duration-200 ${group.key === "services" ? "w-[min(470px,calc(100vw-32px))]" : "w-[min(360px,calc(100vw-32px))]"}`}
              >
                <div class={`relative z-10 rounded-[22px] border p-4 ${navTone.panel}`}>
                  <span class="absolute left-1/2 top-0 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rotate-45 border-l border-t border-[oklch(0.88_0.018_250)] bg-white" aria-hidden="true"></span>
                  <div class="grid gap-1">
                    {group.items.map((item) => (
                      <a
                        href={item.href}
                        aria-current={isActive(item.href) ? "page" : undefined}
                        class={`group grid min-h-[64px] grid-cols-[44px_1fr] items-center gap-3 rounded-[14px] p-2.5 transition hover:bg-[oklch(0.965_0.014_245)] active:scale-[0.985] ${isActive(item.href) ? navTone.active : ""}`}
                      >
                        <span class={`grid h-11 w-11 shrink-0 place-items-center rounded-[12px] ${item.iconBg} ${item.iconText} transition group-hover:scale-[1.03]`}>
                          <Icon name={item.icon} size={19} />
                        </span>
                        <span>
                          <span class="block text-[15px] font-black leading-tight text-[oklch(0.2_0.035_260)]">{item.label}</span>
                          <span class="mt-0.5 block text-[13px] font-semibold leading-5 text-[oklch(0.48_0.045_260)]">{item.description}</span>
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
        <a href="/preise" aria-current={isActive("/preise") ? "page" : undefined} class={`inline-flex min-h-10 items-center rounded-full px-3.5 py-2 text-[13px] font-extrabold leading-[1.35] transition active:scale-[0.97] ${navTone.link} ${isActive("/preise") ? navTone.active : ""}`}>
          Preise
        </a>
        <a href="/enterprise" aria-current={isActive("/enterprise") ? "page" : undefined} class={`inline-flex min-h-10 items-center rounded-full px-3.5 py-2 text-[13px] font-extrabold leading-[1.35] transition active:scale-[0.97] ${navTone.link} ${isActive("/enterprise") ? navTone.active : ""}`}>
          Enterprise
        </a>
        <a href="/kontakt" aria-current={isActive("/kontakt") ? "page" : undefined} class={`inline-flex min-h-10 items-center rounded-full px-3.5 py-2 text-[13px] font-extrabold leading-[1.35] transition active:scale-[0.97] ${navTone.link} ${isActive("/kontakt") ? navTone.active : ""}`}>
          Kontakt
        </a>
      </nav>

      <div class="flex items-center justify-end gap-2">
        <a
          href="/kontakt"
          class={`group hidden min-h-10 items-center gap-2 rounded-full px-4 py-2 text-[13px] font-extrabold leading-[1.35] shadow-[0_10px_22px_oklch(0.18_0.035_260/0.14)] transition hover:-translate-y-0.5 active:translate-y-0 lg:inline-flex ${navTone.button}`}
        >
          {siteContent.navigation.ctaLabel}
          <Icon name="ArrowRight" size={15} class="transition-transform group-hover:translate-x-0.5" />
        </a>
        <button
          type="button"
          class={`grid h-10 w-10 place-items-center rounded-full transition hover:bg-[oklch(0.95_0.014_250)] active:scale-[0.96] lg:hidden ${navTone.link}`}
          aria-label={siteContent.navigation.menuOpen}
          aria-expanded="false"
          data-mobile-toggle
        >
          <span data-menu-icon-open><Icon name="Menu" size={20} /></span>
          <span data-menu-icon-close hidden><Icon name="X" size={20} /></span>
        </button>
      </div>
    </div>

    <div class={`dw-mobile-menu mt-3 rounded-[22px] border p-3 shadow-[0_18px_44px_oklch(0.18_0.035_250/0.12)] lg:hidden ${navTone.panel}`} data-mobile-panel hidden>
      <div class="grid gap-2" data-mobile-main>
        {
          navGroups.map((group) => (
            <button
              type="button"
              class={`flex items-center justify-between rounded-[18px] bg-[oklch(0.965_0.014_245)] p-4 text-left transition hover:bg-[oklch(0.93_0.026_245)] active:scale-[0.985] ${isGroupActive(group) ? navTone.active : ""}`}
              data-mobile-open={group.key}
            >
              <span class="font-display text-lg font-black">{group.label}</span>
              <Icon name="ArrowRight" size={18} />
            </button>
          ))
        }
        {
          topLinks.map(([label, href]) => (
            <a
              href={href}
              class={`rounded-[18px] bg-[oklch(0.965_0.014_245)] p-4 text-left font-display text-lg font-black transition hover:bg-[oklch(0.93_0.026_245)] active:scale-[0.985] ${isActive(href) ? navTone.active : ""}`}
            >
              {label}
            </a>
          ))
        }
        <a href="/kontakt" class={`rounded-[18px] p-4 text-left font-display text-lg font-black transition active:scale-[0.985] ${navTone.button}`}>
          {siteContent.navigation.ctaLabel}
        </a>
      </div>

      {
        navGroups.map((group) => (
          <div data-mobile-view={group.key} hidden>
            <button
              type="button"
              class="mb-3 inline-flex items-center gap-2 rounded-full bg-[oklch(0.965_0.014_245)] px-3 py-2 text-sm font-black transition hover:bg-[oklch(0.93_0.026_245)] active:scale-[0.985]"
              data-mobile-back
            >
              <Icon name="ChevronLeft" size={16} />
              Zurück
            </button>
            <p class="px-2 font-display text-2xl font-black">{group.label}</p>
            <div class="mt-4 grid gap-2">
              {group.items.map((item) => (
                <a
                  href={item.href}
                  class={`grid min-h-[82px] grid-cols-[auto_1fr] items-start gap-3 rounded-[18px] p-3 text-left transition hover:bg-[oklch(0.965_0.014_245)] active:scale-[0.985] ${isActive(item.href) ? navTone.active : ""}`}
                >
                  <span class={`grid h-11 w-11 shrink-0 place-items-center rounded-[15px] ${item.iconBg} ${item.iconText}`}>
                    <Icon name={item.icon} size={20} />
                  </span>
                  <span>
                    <span class="block text-sm font-extrabold leading-5">{item.label}</span>
                    <span class="mt-1 line-clamp-2 block text-xs leading-5 text-[oklch(0.45_0.035_260)]">{item.description}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLElement>("[data-nav-root]").forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
    const panel = root.querySelector<HTMLElement>("[data-mobile-panel]");
    const main = root.querySelector<HTMLElement>("[data-mobile-main]");
    const openIcon = root.querySelector<HTMLElement>("[data-menu-icon-open]");
    const closeIcon = root.querySelector<HTMLElement>("[data-menu-icon-close]");
    const viewPanels = Array.from(root.querySelectorAll<HTMLElement>("[data-mobile-view]"));

    if (!toggle || !panel || !main || !openIcon || !closeIcon) return;

    const showView = (key: string | null) => {
      main.hidden = key !== null;
      viewPanels.forEach((view) => {
        view.hidden = view.dataset.mobileView !== key;
      });
    };

    const setOpen = (open: boolean) => {
      panel.hidden = !open;
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
      openIcon.hidden = open;
      closeIcon.hidden = !open;
      if (!open) showView(null);
    };

    toggle.addEventListener("click", () => setOpen(panel.hidden));

    root.querySelectorAll<HTMLElement>("[data-mobile-open]").forEach((button) => {
      button.addEventListener("click", () => showView(button.dataset.mobileOpen ?? null));
    });

    root.querySelectorAll<HTMLElement>("[data-mobile-back]").forEach((button) => {
      button.addEventListener("click", () => showView(null));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });

    document.addEventListener("pointerdown", (event) => {
      if (!root.contains(event.target as Node)) setOpen(false);
    });
  });
</script>
