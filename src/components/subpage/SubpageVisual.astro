---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";
import type { CurrentPage, PageDetail, PageFamily } from "../../lib/pageContent";

type Props = {
  family: PageFamily;
  current: CurrentPage;
  detail: PageDetail | null;
};

const { family, current, detail } = Astro.props;
const rows = detail?.includes ?? current.bullets;
const methodSteps = detail?.process ?? siteContent.home.one.process.map((step) => step.title);
const agencyItems = detail?.outcomes ?? siteContent.home.one.whyItems.map((item) => item.title);
---

{
  family === "paid" ? (
    <div class="dw-panel-enter rounded-[28px] bg-[var(--dw-dark)] p-5 text-white shadow-[0_18px_58px_oklch(0.16_0.03_32/0.2)]">
      <div class="border-b border-white/16 pb-5">
        <div class="flex items-center justify-between gap-4">
          <p class="font-display text-3xl font-semibold">Kampagnenplan</p>
          <Icon name="Megaphone" size={26} class="text-[var(--dw-accent)]" />
        </div>
        <p class="mt-3 max-w-lg text-sm font-semibold leading-6 text-white/70">Von der Suchabsicht bis zur Anfrage: Jeder Schritt bekommt eine klare Aufgabe.</p>
      </div>
      <div class="mt-6 grid gap-4">
        {rows.slice(0, 3).map((item) => (
          <div class="grid gap-3 rounded-2xl bg-white/[0.07] p-4 md:grid-cols-[170px_1fr]">
            <span class="text-sm font-black text-[var(--dw-accent)]">Prüfpunkt</span>
            <p class="text-sm font-semibold leading-6 text-white/78">{item}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 grid grid-cols-3 gap-2 text-center text-xs font-black text-white/78">
        {["Suchintention", "Anzeigenversprechen", "Zielseite"].map((item) => <span class="rounded-xl border border-white/12 px-3 py-3">{item}</span>)}
      </div>
    </div>
  ) : family === "design" ? (
    <div class="dw-panel-enter overflow-hidden rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5 shadow-[0_18px_50px_oklch(0.18_0.03_210/0.1)]">
      <div class="rounded-[22px] bg-[linear-gradient(135deg,white,oklch(0.93_0.04_195))] p-5">
        <div class="flex items-center gap-2 border-b border-[oklch(0.84_0.024_265)] pb-4">
          <span class="h-3 w-3 rounded-full bg-[var(--dw-accent)]"></span>
          <span class="h-3 w-3 rounded-full bg-[oklch(0.86_0.05_80)]"></span>
          <span class="h-3 w-3 rounded-full bg-[oklch(0.86_0.05_330)]"></span>
        </div>
        <div class="mt-8 grid gap-5 md:grid-cols-[0.9fr_1.1fr]">
          <div>
            <Icon name="Monitor" size={30} class="text-[var(--dw-accent)]" />
            <p class="mt-14 font-display text-4xl font-semibold leading-tight">{current.title}</p>
          </div>
          <div class="grid gap-3">
            {rows.slice(0, 3).map((item) => <p class="rounded-2xl bg-white p-4 text-sm font-semibold leading-6 shadow-sm">{item}</p>)}
          </div>
        </div>
      </div>
    </div>
  ) : family === "pricing" ? (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5 shadow-[0_18px_50px_oklch(0.18_0.03_265/0.1)]">
      <div class="grid gap-3">
        {siteContent.pricingModels.slice(0, 3).map((model) => (
          <div class="grid gap-2 border-b border-[oklch(0.86_0.025_265)] py-4 last:border-b-0 md:grid-cols-[1fr_auto]">
            <p class="font-display text-xl font-semibold">{model.title}</p>
            <p class="font-display text-xl font-semibold text-[var(--dw-accent)]">{model.price}</p>
          </div>
        ))}
      </div>
    </div>
  ) : family === "cases" ? (
    <div class="dw-panel-enter grid gap-3 rounded-[28px] bg-[var(--dw-dark)] p-5 text-white md:grid-cols-3">
      {siteContent.home.one.projectTypes.map((item) => (
        <div class="min-h-[190px] border border-white/14 p-4">
          <Icon name="BriefcaseBusiness" class="text-[var(--dw-accent)]" />
          <p class="mt-16 text-pretty font-display text-2xl font-semibold leading-tight">{item.title}</p>
        </div>
      ))}
    </div>
  ) : family === "method" ? (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5">
      <div class="grid gap-3">
        {methodSteps.map((step, index) => (
          <div class="grid grid-cols-[70px_1fr] items-center border-b border-[oklch(0.86_0.025_265)] py-4 last:border-b-0">
            <span class="font-display text-3xl font-semibold text-[var(--dw-accent)]">{String(index + 1).padStart(2, "0")}</span>
            <p class="font-display text-2xl font-semibold">{step}</p>
          </div>
        ))}
      </div>
    </div>
  ) : family === "agency" ? (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5 shadow-[0_18px_50px_oklch(0.18_0.03_245/0.1)]">
      <div class="rounded-[22px] bg-[linear-gradient(135deg,oklch(0.91_0.04_245),white_48%,oklch(0.91_0.04_190))] p-6">
        <p class="max-w-md font-editorial text-4xl font-semibold italic leading-tight text-[oklch(0.42_0.12_245)]">Ruhige Strategie. Saubere Umsetzung. Keine Show.</p>
        <div class="mt-10 grid gap-3">
          {agencyItems.slice(0, 3).map((item) => <p class="rounded-full bg-white/75 px-4 py-3 text-sm font-black shadow-sm">{item}</p>)}
        </div>
      </div>
    </div>
  ) : family === "enterprise" ? (
    <div class="dw-panel-enter rounded-[28px] bg-[var(--dw-dark)] p-5 text-white shadow-[0_18px_58px_oklch(0.16_0.03_210/0.22)]">
      <div class="grid gap-3 md:grid-cols-3">
        {["Teams", "Daten", "Märkte"].map((item) => (
          <div class="min-h-[116px] rounded-2xl border border-white/12 bg-white/[0.06] p-4">
            <Icon name="Layers" class="text-[var(--dw-accent)]" />
            <p class="mt-8 text-sm font-black">{item}</p>
          </div>
        ))}
      </div>
      <div class="mt-5 rounded-2xl border border-white/12 bg-white/[0.055] p-4">
        {(detail?.includes ?? []).slice(0, 3).map((item) => <p class="border-b border-white/12 py-4 text-sm font-semibold leading-6 text-white/76 last:border-b-0">{item}</p>)}
      </div>
    </div>
  ) : family === "contact" ? (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5 shadow-[0_18px_50px_oklch(0.18_0.03_320/0.1)]">
      <div class="rounded-[22px] bg-[oklch(0.97_0.014_320)] p-6">
        <Icon name="Mail" size={30} class="text-[var(--dw-accent)]" />
        <p class="mt-16 font-display text-4xl font-semibold leading-tight">Eine kurze Nachricht reicht für den Anfang.</p>
        <p class="mt-5 text-sm font-semibold leading-7 text-[oklch(0.35_0.04_265)]">{siteContent.brand.responseTime}</p>
      </div>
    </div>
  ) : family === "resource" ? (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5">
      <div class="grid gap-3">
        {current.bullets.map((item) => <p class="border-b border-[oklch(0.86_0.025_265)] py-4 font-display text-2xl font-semibold last:border-b-0">{item}</p>)}
      </div>
    </div>
  ) : (
    <div class="dw-panel-enter rounded-[28px] border border-[oklch(0.82_0.022_265)] bg-white p-5 shadow-[0_18px_50px_oklch(0.18_0.03_265/0.1)]">
      <div class="grid gap-5 md:grid-cols-[0.86fr_1.14fr]">
        <div class="rounded-[22px] bg-[var(--dw-dark)] p-5 text-white">
          <Icon name="SearchCheck" size={32} class="text-[var(--dw-accent)]" />
          <p class="mt-16 font-display text-3xl font-semibold leading-tight">Suchstruktur, die verstanden wird.</p>
        </div>
        <div class="grid content-center gap-3">
          {rows.slice(0, 4).map((item, index) => (
            <div class="grid grid-cols-[40px_1fr] gap-3 border-t border-[oklch(0.84_0.024_265)] pt-4">
              <span class="font-display text-2xl font-semibold text-[var(--dw-accent)]">{index + 1}</span>
              <p class="text-sm font-semibold leading-6 text-[oklch(0.32_0.04_265)]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}
