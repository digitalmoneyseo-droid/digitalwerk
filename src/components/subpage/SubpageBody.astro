---
import Icon from "../Icon.astro";
import ProcessAndFaq from "../shared/ProcessAndFaq.astro";
import { siteContent } from "../../data/siteContent";
import { corePageConfigs, type CurrentPage, type PageDetail, type PageFamily } from "../../lib/pageContent";

type Props = {
  family: PageFamily;
  current: CurrentPage;
  detail: PageDetail | null;
};

const { family, current, detail } = Astro.props;
const labels = siteContent.pageDetailLabels;
const coreConfig = corePageConfigs[current.href] ?? null;
const includes = detail?.includes ?? current.bullets;
const outcomes = detail?.outcomes ?? current.bullets;
const process = detail?.process ?? [];
const faq = detail?.faq ?? [];
const isPricing = family === "pricing";
const isContact = family === "contact";
const fallbackColumnTitles = ["Analyse", "Struktur", "Umsetzung", "Optimierung"] as const;
const pricingCards = siteContent.pricingCards;
const fieldClass =
  "min-h-12 rounded-md border border-[var(--dw-card-border)] bg-white px-4 text-base font-medium outline-none transition hover:border-[oklch(0.74_0.04_250)] focus:border-[var(--dw-accent)]";
const textareaClass =
  "min-h-36 rounded-md border border-[var(--dw-card-border)] bg-white px-4 py-3 text-base font-medium leading-7 outline-none transition hover:border-[oklch(0.74_0.04_250)] focus:border-[var(--dw-accent)]";
---

{
  !isPricing && !isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="dw-container grid gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">{coreConfig?.headline ?? detail?.whyTitle ?? current.title}</h2>
          <p class="mt-6 max-w-md text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)]">{coreConfig?.lead ?? detail?.whyText ?? current.intro}</p>
        </div>
        <div class="border-y border-[var(--dw-card-border)]">
          {(coreConfig?.columns ?? includes.map((item, index) => ({ title: fallbackColumnTitles[index] ?? "Begleitung", text: item }))).slice(0, 4).map((item) => (
            <article class="grid gap-3 border-b border-[var(--dw-card-border)] py-6 last:border-b-0 md:grid-cols-[180px_1fr]">
              <h3 class="text-lg font-black text-[var(--dw-ink)]">{item.title}</h3>
              <p class="text-sm font-medium leading-7 text-[var(--dw-ink-soft)]">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  !isPricing && !isContact && (
    <section class="px-5 py-16 md:py-24">
      <div class="dw-container grid gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">{coreConfig?.proofTitle ?? labels.outcomes}</h2>
        <div class="dw-reveal-stagger grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
          {outcomes.map((item) => (
            <div class="flex items-start gap-3 rounded-lg border border-[var(--dw-card-border)] bg-white/88 p-5 shadow-[var(--dw-card-shadow-tight)]">
              <Icon name="CircleCheckBig" size={18} class="mt-1 shrink-0 text-[var(--dw-green)]" />
              <p class="text-sm font-bold leading-7 text-[var(--dw-ink)]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isPricing && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="dw-container">
        <div class="dw-reveal mx-auto max-w-3xl text-center">
          <h2 class="text-balance break-words font-display text-4xl font-black leading-[1.05] tracking-[-0.025em] text-[var(--dw-ink)] sm:text-5xl md:text-6xl">Klare Einstiegspakete</h2>
          <p class="mt-6 text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
            Transparente Richtwerte für Websites, Relaunches und laufende Betreuung. Der konkrete Umfang entsteht nach dem Erstgespräch.
          </p>
        </div>
        <div class="dw-reveal-stagger mt-12 grid gap-5 lg:grid-cols-3 lg:items-stretch">
          {pricingCards.map((plan) => (
            <article
              class={`relative flex min-h-[560px] flex-col rounded-lg border p-6 ${
                plan.featured
                  ? "border-[oklch(0.22_0.045_255)] bg-[var(--dw-dark)] text-white lg:-mt-5"
                  : "border-[var(--dw-card-border)] bg-white text-[var(--dw-ink)]"
              }`}
            >
              {plan.featured && (
                <span class="absolute right-5 top-5 rounded-full bg-white px-3 py-1 text-xs font-black text-[var(--dw-dark)]">
                  Häufigster Einstieg
                </span>
              )}
              <p class={`text-sm font-black ${plan.featured ? "pr-36 text-white/82" : "text-[var(--dw-accent-strong)]"}`}>{plan.name}</p>
              <p class={`mt-4 text-base font-medium leading-7 ${plan.featured ? "text-white/72" : "text-[var(--dw-ink-soft)]"}`}>{plan.lead}</p>
              <p class="mt-8 font-display text-4xl font-black leading-none tracking-[-0.035em] md:text-5xl">{plan.price}</p>
              <div class={`my-7 h-px ${plan.featured ? "bg-white/14" : "bg-[var(--dw-card-border)]"}`}></div>
              <ul class="grid gap-3">
                {plan.features.map((feature) => (
                  <li class={`flex items-start gap-3 text-sm font-medium leading-6 ${plan.featured ? "text-white/84" : "text-[var(--dw-ink-soft)]"}`}>
                    <Icon name="CircleCheckBig" size={17} class={`mt-1 shrink-0 ${plan.featured ? "text-[oklch(0.78_0.12_155)]" : "text-[var(--dw-green)]"}`} />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/kontakt"
                class={`mt-auto inline-flex min-h-12 items-center justify-center rounded-full px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 active:translate-y-0 ${
                  plan.featured
                    ? "bg-white text-[var(--dw-dark)]"
                    : "border border-[oklch(0.78_0.04_250)] bg-white text-[var(--dw-ink)] hover:border-[var(--dw-accent)]"
                }`}
              >
                Plan anfragen
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="dw-container grid gap-10 lg:grid-cols-[0.38fr_0.62fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">Kurz schildern. Klar starten.</h2>
          <p class="mt-6 max-w-md text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
            Wir melden uns mit einer klaren Einschätzung und sagen, welcher nächste Schritt sinnvoll ist.
          </p>
          <div class="mt-8 grid gap-3 text-sm font-medium leading-6 text-[var(--dw-ink-soft)]">
            <p>{siteContent.brand.addressLine}</p>
            <p>{siteContent.brand.responseTime}</p>
            <a class="inline-flex min-h-11 items-center font-black text-[var(--dw-accent-strong)]" href={`mailto:${siteContent.brand.email}`}>{siteContent.brand.email}</a>
          </div>
        </div>
        <div>
          <div class="mb-6 rounded-lg border border-[oklch(0.74_0.1_155)] bg-[oklch(0.965_0.04_155)] p-5 text-sm font-bold leading-6 text-[oklch(0.3_0.1_155)]" role="status" aria-live="polite" data-contact-success hidden>
            Danke. Die Anfrage wurde gesendet. Wir melden uns innerhalb von 1-2 Werktagen.
          </div>
          <div class="mb-6 rounded-lg border border-[oklch(0.72_0.13_32)] bg-[oklch(0.965_0.04_32)] p-5 text-sm font-bold leading-6 text-[oklch(0.34_0.12_32)]" role="alert" data-contact-error hidden>
            Die Anfrage konnte nicht gesendet werden. Bitte prüfe die Pflichtfelder oder schreib direkt an {siteContent.brand.email}.
          </div>
          <form class="border-t border-[var(--dw-card-border)] pt-6" action="/api/contact" method="post" data-contact-form>
            <div class="grid gap-5 md:grid-cols-2">
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)]">
                Name
                <input name="name" required class={fieldClass} placeholder="Vor- und Nachname" autocomplete="name" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)]">
                Unternehmen / Branche
                <input name="unternehmen" class={fieldClass} placeholder="Firma, Praxis oder Branche" autocomplete="organization" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)]">
                E-Mail
                <input name="email" type="email" required class={fieldClass} placeholder="name@unternehmen.de" autocomplete="email" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)]">
                Telefon / WhatsApp
                <input name="phone" class={fieldClass} placeholder="+49 ..." autocomplete="tel" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)] md:col-span-2">
                Website
                <input name="website" class={fieldClass} placeholder="https://..." inputmode="url" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)] md:col-span-2">
                Wobei brauchst du Hilfe?
                <select name="thema" required class={fieldClass}>
                  <option value="">Bitte einordnen</option>
                  <option>Webdesign / Relaunch</option>
                  <option>SEO / lokale Sichtbarkeit</option>
                  <option>Paid Ads / Werbekampagnen</option>
                  <option>KI & Automation</option>
                  <option>Noch unklar</option>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-black text-[var(--dw-ink)] md:col-span-2">
                Was soll sich verbessern?
                <textarea
                  name="ausgangslage"
                  required
                  class={textareaClass}
                  placeholder="Zum Beispiel: neue Website, Relaunch, mehr lokale Anfragen, bessere Landingpage, SEO, Ads ..."
                ></textarea>
              </label>
              <label class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
                Website URL
                <input name="website_url_confirm" tabindex="-1" autocomplete="off" />
              </label>
            </div>
            <button type="submit" class="group mt-6 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white transition hover:-translate-y-0.5 active:translate-y-0" data-submit-label="Kostenloses Erstgespräch anfragen" data-loading-label="Anfrage wird gesendet ...">
              <span data-submit-text>Kostenloses Erstgespräch anfragen</span>
              <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
            </button>
          </form>
        </div>
      </div>
    </section>
  )
}

{!isContact && !isPricing && <ProcessAndFaq process={process} faq={faq} />}

<script>
  const params = new URLSearchParams(window.location.search);

  if (params.get("sent") === "1") {
    document.querySelectorAll<HTMLElement>("[data-contact-success]").forEach((element) => {
      element.hidden = false;
    });
  }

  if (params.get("error")) {
    document.querySelectorAll<HTMLElement>("[data-contact-error]").forEach((element) => {
      element.hidden = false;
    });
  }

  document.querySelectorAll<HTMLFormElement>("[data-contact-form]").forEach((form) => {
    form.addEventListener("submit", () => {
      const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
      const text = form.querySelector<HTMLElement>("[data-submit-text]");
      if (!button || !text) return;
      button.disabled = true;
      text.textContent = button.dataset.loadingLabel ?? "Anfrage wird gesendet ...";
    });
  });
</script>
