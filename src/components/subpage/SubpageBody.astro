---
import Icon from "../Icon.astro";
import ProcessAndFaq from "../shared/ProcessAndFaq.astro";
import { siteContent } from "../../data/siteContent";
import { corePageConfigs, type CurrentPage, type PageDetail, type PageFamily } from "../../lib/pageContent";

type Props = {
  family: PageFamily;
  current: CurrentPage;
  detail: PageDetail | null;
};

const { family, current, detail } = Astro.props;
const labels = siteContent.pageDetailLabels;
const coreConfig = corePageConfigs[current.href] ?? null;
const includes = detail?.includes ?? current.bullets;
const outcomes = detail?.outcomes ?? current.bullets;
const process = detail?.process ?? [];
const faq = detail?.faq ?? [];
const isPricing = family === "pricing";
const isContact = family === "contact";
const fallbackColumnTitles = ["Analyse", "Struktur", "Umsetzung", "Optimierung"] as const;
const pricingCards = siteContent.pricingCards;
const fieldClass =
  "min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]";
---

{
  !isPricing && !isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-extrabold leading-[1.05] text-[oklch(0.22_0.04_260)] md:text-5xl">{coreConfig?.headline ?? detail?.whyTitle ?? current.title}</h2>
          <p class="mt-6 max-w-md text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">{coreConfig?.lead ?? detail?.whyText ?? current.intro}</p>
        </div>
        <div class="border-t border-[var(--dw-line)]">
          {(coreConfig?.columns ?? includes.map((item, index) => ({ title: fallbackColumnTitles[index] ?? "Begleitung", text: item }))).slice(0, 4).map((item) => (
            <article class="grid gap-3 border-b border-[var(--dw-line)] py-6 md:grid-cols-[180px_1fr]">
              <h3 class="font-impact text-lg font-extrabold text-[oklch(0.2_0.035_265)]">{item.title}</h3>
              <p class="text-sm font-semibold leading-7 text-[oklch(0.48_0.04_265)]">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  !isPricing && !isContact && (
    <section class="px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <h2 class="text-balance font-display text-4xl font-extrabold leading-[1.05] text-[oklch(0.22_0.04_260)] md:text-5xl">{coreConfig?.proofTitle ?? labels.outcomes}</h2>
        <div class="dw-reveal-stagger grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {outcomes.map((item) => (
            <div class="flex items-start gap-3 rounded-2xl border border-[var(--dw-card-border)] bg-white/88 p-5 shadow-[var(--dw-card-shadow)]">
              <Icon name="CircleCheckBig" size={18} class="mt-1 shrink-0 text-[var(--dw-accent)]" />
              <p class="text-sm font-extrabold leading-7 text-[oklch(0.28_0.04_265)]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isPricing && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto max-w-[1180px]">
        <div class="mx-auto max-w-3xl text-center dw-reveal">
          <h2 class="text-balance break-words font-display text-4xl font-extrabold leading-[1.05] text-[oklch(0.22_0.04_260)] sm:text-5xl md:text-6xl">Klare Einstiegspakete</h2>
          <p class="mt-6 text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">
            Transparente Richtwerte für Websites, Relaunches und laufende Betreuung. Das genaue Angebot richtet sich nach Umfang, Technik und Ziel.
          </p>
        </div>
        <div class="dw-reveal-stagger mt-12 grid gap-5 lg:grid-cols-3 lg:items-stretch">
          {pricingCards.map((plan) => (
            <article
              class={`relative flex min-h-[560px] flex-col rounded-2xl border p-7 ${
                plan.featured
                  ? "border-[oklch(0.24_0.045_250)] bg-[oklch(0.18_0.045_250)] text-white lg:-mt-6 lg:min-h-[620px]"
                  : "border-[var(--dw-card-border)] bg-white text-[oklch(0.2_0.035_260)] shadow-[var(--dw-card-shadow)]"
              }`}
            >
              {plan.featured && (
                <span class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--dw-accent-strong)] px-6 py-2 text-xs font-black uppercase tracking-[0.12em] text-white">
                  Beliebt
                </span>
              )}
              <p class={`text-[12px] font-black uppercase tracking-[0.16em] ${plan.featured ? "text-[oklch(0.82_0.08_245)]" : "text-[var(--dw-accent-strong)]"}`}>{plan.name}</p>
              <p class={`mt-4 text-lg font-bold leading-7 ${plan.featured ? "text-[oklch(0.9_0.018_245)]" : "text-[oklch(0.42_0.04_260)]"}`}>{plan.lead}</p>
              <p class="mt-10 font-display text-5xl font-extrabold leading-none md:text-6xl">{plan.price}</p>
              <div class={`my-8 h-px ${plan.featured ? "bg-white/14" : "bg-[var(--dw-line)]"}`}></div>
              <ul class="grid gap-4">
                {plan.features.map((feature) => (
                  <li class={`flex items-start gap-3 text-sm font-bold leading-6 ${plan.featured ? "text-[oklch(0.92_0.016_245)]" : "text-[oklch(0.42_0.04_260)]"}`}>
                    <Icon name="CircleCheckBig" size={17} class={`mt-1 shrink-0 ${plan.featured ? "text-[oklch(0.82_0.08_245)]" : "text-[var(--dw-accent-strong)]"}`} />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/kontakt"
                class={`mt-auto inline-flex min-h-12 items-center justify-center rounded-full px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 active:translate-y-0 ${
                  plan.featured
                    ? "bg-white text-[oklch(0.18_0.045_250)]"
                    : "border border-[oklch(0.78_0.03_250)] bg-white text-[oklch(0.22_0.04_260)]"
                }`}
              >
                Plan anfragen
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.38fr_0.62fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-extrabold leading-[1.05] text-[oklch(0.22_0.04_260)] md:text-5xl">Kurz schildern. Klar starten.</h2>
          <p class="mt-6 max-w-md text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">
            Wir melden uns mit einer ehrlichen Einschätzung und sagen klar, welcher nächste Schritt sinnvoll ist.
          </p>
          <div class="mt-8 grid gap-3 text-sm font-semibold leading-6 text-[oklch(0.4_0.04_265)]">
            <p>{siteContent.brand.addressLine}</p>
            <p>{siteContent.brand.responseTime}</p>
            <a class="inline-flex min-h-11 items-center font-black text-[var(--dw-accent)]" href={`mailto:${siteContent.brand.email}`}>{siteContent.brand.email}</a>
          </div>
        </div>
        <div>
          <div class="mb-6 rounded-2xl border border-[oklch(0.82_0.09_150)] bg-[oklch(0.97_0.04_150)] p-5 text-sm font-bold leading-6 text-[oklch(0.32_0.09_150)]" role="status" data-contact-success hidden>
            Danke. Die Anfrage wurde gesendet. Wir melden uns innerhalb von 1 bis 2 Werktagen.
          </div>
          <form class="border-t border-[var(--dw-line)] pt-6" action="/api/contact" method="post">
            <div class="grid gap-5 md:grid-cols-2">
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
                Name
                <input name="name" required class={fieldClass} placeholder="Vor- und Nachname" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
                Unternehmen
                <input name="unternehmen" class={fieldClass} placeholder="Firma oder Organisation" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
                E-Mail
                <input name="email" type="email" required class={fieldClass} placeholder="name@unternehmen.de" />
              </label>
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
                Website
                <input name="website" class={fieldClass} placeholder="https://..." />
              </label>
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)] md:col-span-2">
                Thema
                <select name="thema" required class={fieldClass}>
                  <option value="">Bitte einordnen</option>
                  <option>Webdesign / Relaunch</option>
                  <option>SEO / lokale Sichtbarkeit</option>
                  <option>Paid Ads / Werbekampagnen</option>
                  <option>KI & Automation</option>
                  <option>Noch unklar</option>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)] md:col-span-2">
                Ausgangslage
                <textarea
                  name="ausgangslage"
                  required
                  class="min-h-36 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 py-3 font-semibold leading-7 outline-none transition focus:border-[var(--dw-accent)]"
                  placeholder="Was soll sich verbessern?"
                ></textarea>
              </label>
            </div>
            <button type="submit" class="group mt-6 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white transition hover:-translate-y-0.5 active:translate-y-0">
              Kostenlose Erstberatung anfragen
              <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
            </button>
          </form>
        </div>
      </div>
    </section>
  )
}

{!isContact && !isPricing && <ProcessAndFaq process={process} faq={faq} />}

<script>
  if (new URLSearchParams(window.location.search).get("sent") === "1") {
    document.querySelectorAll<HTMLElement>("[data-contact-success]").forEach((element) => {
      element.hidden = false;
    });
  }
</script>
