---
import Icon from "../Icon.astro";
import ProcessAndFaq from "../shared/ProcessAndFaq.astro";
import { siteContent } from "../../data/siteContent";
import { corePageConfigs, type CurrentPage, type PageDetail, type PageFamily } from "../../lib/pageContent";

type Props = {
  family: PageFamily;
  current: CurrentPage;
  detail: PageDetail | null;
};

const { family, current, detail } = Astro.props;
const labels = siteContent.pageDetailLabels;
const coreConfig = corePageConfigs[current.href] ?? null;
const includes = detail?.includes ?? current.bullets;
const outcomes = detail?.outcomes ?? current.bullets;
const process = detail?.process ?? [];
const faq = detail?.faq ?? [];
const isPricing = family === "pricing";
const isContact = family === "contact";
const fallbackColumnTitles = ["Analyse", "Struktur", "Umsetzung", "Optimierung"] as const;
const pricingCards = [
  {
    name: "Starter",
    lead: "Für den schnellen professionellen Web-Auftritt",
    price: "ab 1.900 €",
    features: ["Responsive Website", "SEO-Grundlage", "Kontaktweg und Tracking", "Launch-Check"],
    featured: false,
  },
  {
    name: "Professional",
    lead: "Website, SEO-Struktur und Kampagnenbasis in einem System",
    price: "ab 4.800 €",
    features: ["Alles aus Starter", "Premium Webdesign", "Leistungsseiten für SEO", "Landingpage für Kampagnen", "Reporting-Grundlage"],
    featured: true,
  },
  {
    name: "Betreuung",
    lead: "Laufende Optimierung für Sichtbarkeit und Anfragen",
    price: "ab 950 € / Monat",
    features: ["SEO- oder Ads-Betreuung", "Tests und Optimierung", "Monatliche Auswertung", "Priorisierte Empfehlungen"],
    featured: false,
  },
] as const;
---

{
  !isPricing && !isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{coreConfig?.headline ?? detail?.whyTitle ?? current.title}</h2>
          <p class="mt-6 max-w-md text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">{coreConfig?.lead ?? detail?.whyText ?? current.intro}</p>
        </div>
        <div class="border-t border-[var(--dw-line)]">
          {(coreConfig?.columns ?? includes.map((item, index) => ({ title: fallbackColumnTitles[index] ?? "Begleitung", text: item }))).slice(0, 4).map((item) => (
            <article class="grid gap-3 border-b border-[var(--dw-line)] py-6 md:grid-cols-[180px_1fr]">
              <h3 class="font-impact text-lg font-extrabold text-[oklch(0.2_0.035_265)]">{item.title}</h3>
              <p class="text-sm font-semibold leading-7 text-[oklch(0.48_0.04_265)]">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  !isPricing && !isContact && (
    <section class="px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr]">
        <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{coreConfig?.proofTitle ?? labels.outcomes}</h2>
        <div class="dw-reveal-stagger grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          {outcomes.map((item) => (
            <div class="flex items-start gap-3 rounded-[22px] border border-[oklch(0.88_0.02_250)] bg-white/82 p-5 shadow-[0_12px_36px_oklch(0.2_0.035_250/0.05)]">
              <Icon name="CircleCheckBig" size={18} class="mt-1 shrink-0 text-[var(--dw-accent)]" />
              <p class="text-sm font-extrabold leading-7 text-[oklch(0.28_0.04_265)]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isPricing && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto max-w-[1180px]">
        <div class="mx-auto max-w-3xl text-center dw-reveal">
          <h2 class="text-balance font-display text-5xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-6xl">Richtwerte</h2>
          <p class="mt-6 text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">
            Beträge sind Orientierung zzgl. MwSt. Externe Tools und Media-Budget werden separat geplant.
          </p>
        </div>
        <div class="dw-reveal-stagger mt-12 grid gap-5 lg:grid-cols-3 lg:items-stretch">
          {pricingCards.map((plan) => (
            <article
              class={`relative flex min-h-[560px] flex-col rounded-[28px] border p-7 shadow-[0_18px_56px_oklch(0.2_0.035_250/0.08)] ${
                plan.featured
                  ? "border-[oklch(0.24_0.045_250)] bg-[oklch(0.18_0.045_250)] text-white lg:-mt-6 lg:min-h-[620px]"
                  : "border-[oklch(0.9_0.018_250)] bg-white text-[oklch(0.2_0.035_260)]"
              }`}
            >
              {plan.featured && (
                <span class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[oklch(0.62_0.15_245)] px-6 py-2 text-xs font-black uppercase tracking-[0.18em] text-white shadow-[0_10px_28px_oklch(0.2_0.08_245/0.28)]">
                  Beliebt
                </span>
              )}
              <p class={`text-[12px] font-black uppercase tracking-[0.24em] ${plan.featured ? "text-[oklch(0.68_0.13_245)]" : "text-[oklch(0.58_0.15_245)]"}`}>{plan.name}</p>
              <p class={`mt-4 text-lg font-bold leading-7 ${plan.featured ? "text-white/68" : "text-[oklch(0.5_0.04_260)]"}`}>{plan.lead}</p>
              <p class="mt-10 font-display text-6xl font-semibold leading-none">{plan.price}</p>
              <div class={`my-8 h-px ${plan.featured ? "bg-white/14" : "bg-[var(--dw-line)]"}`}></div>
              <ul class="grid gap-4">
                {plan.features.map((feature) => (
                  <li class={`flex items-start gap-3 text-sm font-bold leading-6 ${plan.featured ? "text-white/74" : "text-[oklch(0.42_0.04_260)]"}`}>
                    <Icon name="CircleCheckBig" size={17} class={`mt-1 shrink-0 ${plan.featured ? "text-[oklch(0.62_0.15_245)]" : "text-[oklch(0.58_0.15_245)]"}`} />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/kontakt"
                class={`mt-auto inline-flex min-h-12 items-center justify-center rounded-full px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 active:translate-y-0 ${
                  plan.featured
                    ? "bg-[oklch(0.62_0.15_245)] text-white shadow-[0_12px_30px_oklch(0.15_0.08_245/0.28)]"
                    : "border border-[oklch(0.78_0.03_250)] bg-white text-[oklch(0.22_0.04_260)]"
                }`}
              >
                Anfragen
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

{
  isContact && (
    <section class="bg-white px-5 py-16 md:py-24">
      <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.38fr_0.62fr]">
        <div>
          <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">Kurz schildern. Klar starten.</h2>
          <p class="mt-6 max-w-md text-base font-semibold leading-8 text-[oklch(0.48_0.04_265)]">
            Wir melden uns mit einer ehrlichen Einschätzung und sagen klar, welcher nächste Schritt sinnvoll ist.
          </p>
          <div class="mt-8 grid gap-3 text-sm font-semibold leading-6 text-[oklch(0.4_0.04_265)]">
            <p>{siteContent.brand.addressLine}</p>
            <p>{siteContent.brand.responseTime}</p>
            <a class="font-black text-[var(--dw-accent)]" href={`mailto:${siteContent.brand.email}`}>{siteContent.brand.email}</a>
          </div>
        </div>
        <form
          class="border-t border-[var(--dw-line)] pt-6"
          action={`mailto:${siteContent.brand.email}`}
          method="post"
          enctype="text/plain"
        >
          <div class="grid gap-5 md:grid-cols-2">
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
              Name
              <input name="name" required class="min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]" placeholder="Vor- und Nachname" />
            </label>
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
              Unternehmen
              <input name="unternehmen" class="min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]" placeholder="Firma oder Organisation" />
            </label>
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
              E-Mail
              <input name="email" type="email" required class="min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]" placeholder="name@unternehmen.de" />
            </label>
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)]">
              Website
              <input name="website" class="min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]" placeholder="https://..." />
            </label>
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)] md:col-span-2">
              Thema
              <select name="thema" required class="min-h-12 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 font-semibold outline-none transition focus:border-[var(--dw-accent)]">
                <option value="">Bitte einordnen</option>
                <option>Webdesign / Relaunch</option>
                <option>SEO / lokale Sichtbarkeit</option>
                <option>Paid Ads / Werbekampagnen</option>
                <option>Social Media / Branding</option>
                <option>Noch unklar</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-black text-[oklch(0.24_0.035_265)] md:col-span-2">
              Ausgangslage
              <textarea
                name="ausgangslage"
                required
                class="min-h-36 rounded-xl border border-[oklch(0.82_0.024_265)] bg-white px-4 py-3 font-semibold leading-7 outline-none transition focus:border-[var(--dw-accent)]"
                placeholder="Was soll sich verbessern?"
              ></textarea>
            </label>
          </div>
          <button type="submit" class="group mt-6 inline-flex items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white shadow-[0_10px_24px_oklch(0.16_0.03_265/0.14)] transition hover:-translate-y-0.5 active:translate-y-0">
            {detail?.ctaLabel ?? "Anfrage senden"}
            <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
          </button>
        </form>
      </div>
    </section>
  )
}

{!isContact && !isPricing && <ProcessAndFaq process={process} faq={faq} />}
