---
import Icon from "../Icon.astro";
import SubpageBody from "./SubpageBody.astro";
import { siteContent, type Subpage } from "../../data/siteContent";
import { familyThemes, getPageDetail, getPageFamily, type CurrentPage } from "../../lib/pageContent";

type Props = {
  page: Subpage | CurrentPage;
};

const { page } = Astro.props;
const current = page as CurrentPage;
const detail = getPageDetail(current);
const family = getPageFamily(current);
const theme = familyThemes[family];
const style = `--dw-accent: ${theme.accent}; --dw-wash: ${theme.wash}; --dw-dark: ${theme.dark};`;
const heroItems = detail?.outcomes ?? current.bullets;
---

<main class="min-h-screen bg-[var(--dw-wash)] text-[oklch(0.17_0.025_265)]" style={style}>
  <section class="relative overflow-hidden px-5 pb-16 pt-32 md:pb-24 md:pt-40">
    <div class="dw-page-grid absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-[1180px]">
      <a
        href="/"
        class="mb-10 inline-flex items-center gap-2 rounded-full border border-[oklch(0.78_0.025_265)] bg-white/78 px-4 py-2 text-sm font-black shadow-sm transition hover:-translate-x-0.5 hover:bg-white active:scale-[0.97]"
      >
        <Icon name="ArrowLeft" size={16} />
        {siteContent.subpageTemplate.backLabel}
      </a>

      <div class="grid gap-12 lg:grid-cols-[0.58fr_0.42fr] lg:items-end">
        <div class="page-rise">
          <h1 class="max-w-4xl text-balance font-display text-5xl font-semibold leading-[0.98] text-[oklch(0.2_0.035_260)] md:text-7xl">{current.title}</h1>
          <p class="mt-8 max-w-3xl text-pretty text-base font-semibold leading-8 text-[oklch(0.46_0.04_265)] md:text-lg">{current.intro}</p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a href="/kontakt" class="group inline-flex min-h-11 items-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white shadow-[0_10px_24px_oklch(0.16_0.03_265/0.14)] transition hover:-translate-y-0.5 active:translate-y-0">
              {detail?.ctaLabel ?? siteContent.subpageTemplate.ctaLabel}
              <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
            </a>
            <a href="/preise" class="inline-flex min-h-11 items-center gap-2 rounded-full border border-current/20 bg-white/78 px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 hover:bg-white active:translate-y-0">
              Preise ansehen
            </a>
          </div>
        </div>

        <div class="border-t border-[var(--dw-line)]">
          {heroItems.slice(0, 3).map((item) => (
            <p class="border-b border-[var(--dw-line)] py-5 text-sm font-extrabold leading-7 text-[oklch(0.28_0.04_265)]">{item}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <SubpageBody family={family} current={current} detail={detail} />
</main>
