---
import Icon from "../Icon.astro";
import SubpageBody from "./SubpageBody.astro";
import { siteContent, type Subpage } from "../../data/siteContent";
import { familyThemes, getPageDetail, getPageFamily, type CurrentPage } from "../../lib/pageContent";

type Props = {
  page: Subpage | CurrentPage;
};

const { page } = Astro.props;
const current = page as CurrentPage;
const detail = getPageDetail(current);
const family = getPageFamily(current);
const theme = familyThemes[family];
const style = `--dw-accent: ${theme.accent}; --dw-accent-strong: ${theme.accentStrong}; --dw-wash: ${theme.wash}; --dw-dark: ${theme.dark};`;
const heroItems = detail?.outcomes ?? current.bullets;
---

<main id="main-content" class="min-h-screen bg-[var(--dw-wash)] text-[var(--dw-ink)]" style={style}>
  <section class="relative overflow-hidden px-5 pb-16 pt-32 md:pb-24 md:pt-40">
    <div class="dw-page-grid absolute inset-0" aria-hidden="true"></div>
    <div class="relative dw-container">
      <div class="grid gap-12 lg:grid-cols-[0.6fr_0.4fr] lg:items-end">
        <div class="page-rise">
          <p class="dw-kicker">{current.category}</p>
          <h1 class="mt-6 max-w-4xl text-balance font-display text-4xl font-black leading-[1.04] tracking-[-0.03em] text-[var(--dw-ink)] md:text-6xl">
            {current.title}
          </h1>
          <p class="mt-7 max-w-3xl text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)] md:text-lg">
            {current.intro}
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <a href="/kontakt" class="group inline-flex min-h-12 items-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white transition hover:-translate-y-0.5 active:translate-y-0">
              {detail?.ctaLabel ?? siteContent.subpageTemplate.ctaLabel}
              <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
            </a>
            <a href="/preise" class="inline-flex min-h-12 items-center gap-2 rounded-full border border-current/20 bg-white/[0.78] px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 hover:bg-white active:translate-y-0">
              Preise ansehen
            </a>
          </div>
        </div>

        <div class="rounded-lg border border-[var(--dw-card-border)] bg-white/82 p-5 shadow-[var(--dw-card-shadow-tight)]">
          <p class="text-sm font-black text-[var(--dw-accent-strong)]">{siteContent.subpageTemplate.overviewLabel}</p>
          <div class="mt-4 border-t border-[var(--dw-card-border)]">
            {heroItems.slice(0, 3).map((item) => (
              <p class="border-b border-[var(--dw-card-border)] py-4 text-sm font-bold leading-7 text-[var(--dw-ink)]">{item}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <SubpageBody family={family} current={current} detail={detail} />
</main>
