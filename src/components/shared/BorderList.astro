---
type Props = {
  title: string;
  items: readonly string[];
};

const { title, items } = Astro.props;
---

<div class="border-y border-[var(--dw-card-border)]">
  <p class="py-5 text-sm font-black text-[var(--dw-accent-strong)]">{title}</p>
  {
    items.map((item) => (
      <p class="border-t border-[var(--dw-card-border)] py-5 text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
        {item}
      </p>
    ))
  }
</div>
