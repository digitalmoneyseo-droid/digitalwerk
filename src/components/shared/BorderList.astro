---
type Props = {
  title: string;
  items: readonly string[];
};

const { title, items } = Astro.props;
---

<div class="border-y border-[oklch(0.78_0.03_265)]">
  <p class="py-5 text-sm font-black text-[var(--dw-accent)]">{title}</p>
  {
    items.map((item) => (
      <p class="border-t border-[oklch(0.86_0.025_265)] py-5 text-pretty text-base font-semibold leading-8 text-[oklch(0.34_0.04_265)]">
        {item}
      </p>
    ))
  }
</div>
