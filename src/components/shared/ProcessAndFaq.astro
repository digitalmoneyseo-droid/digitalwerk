---
import SectionShell from "./SectionShell.astro";
import { siteContent } from "../../data/siteContent";

type Props = {
  process: readonly string[];
  faq: readonly { question: string; answer: string }[];
};

const { process, faq } = Astro.props;
const labels = siteContent.pageDetailLabels;
---

{
  (process.length || faq.length) ? (
    <SectionShell>
      <div class="mx-auto grid max-w-[1180px] min-w-0 gap-12 lg:grid-cols-[minmax(0,0.5fr)_minmax(0,0.5fr)]">
        {process.length ? (
          <div class="min-w-0">
            <h2 class="font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{labels.process}</h2>
            <div class="mt-8 border-t border-[var(--dw-line)]">
              {process.map((step, index) => (
                <div class="grid grid-cols-[70px_1fr] items-center border-b border-[var(--dw-line)] py-5">
                  <span class="font-display text-3xl font-semibold text-[var(--dw-accent)]">{String(index + 1).padStart(2, "0")}</span>
                  <p class="font-impact text-base font-extrabold">{step}</p>
                </div>
              ))}
            </div>
          </div>
        ) : null}
        {faq.length ? (
          <div class="min-w-0">
            <h2 class="font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{labels.faq}</h2>
            <div class="mt-8 border-t border-[var(--dw-line)]">
              {faq.map((item) => (
                <details class="group border-b border-[var(--dw-line)] py-5">
                  <summary class="cursor-pointer list-none font-impact text-base font-extrabold outline-none focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-offset-4 focus-visible:outline-[var(--dw-accent)]">
                    {item.question}
                    <span class="float-right transition group-open:rotate-45">+</span>
                  </summary>
                  <p class="mt-4 text-sm font-semibold leading-7 text-[oklch(0.48_0.04_265)]">{item.answer}</p>
                </details>
              ))}
            </div>
          </div>
        ) : null}
      </div>
    </SectionShell>
  ) : null
}
