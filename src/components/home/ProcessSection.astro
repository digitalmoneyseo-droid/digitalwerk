---
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="px-5 py-20 md:py-28">
  <div class="dw-container grid gap-10 lg:grid-cols-[0.38fr_0.62fr]">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">
        {content.processTitle}
      </h2>
      <p class="mt-5 max-w-md text-base font-medium leading-8 text-[var(--dw-ink-soft)]">{content.processLead}</p>
    </div>

    <div class="dw-reveal-stagger border-y border-[var(--dw-card-border)]">
      {content.process.map((step, index) => (
        <article class="grid gap-3 border-b border-[var(--dw-card-border)] py-6 last:border-b-0 md:grid-cols-[4.5rem_12rem_1fr]">
          <p class="font-display text-4xl font-black leading-none tracking-[-0.04em] text-[var(--dw-accent-strong)]">
            {String(index + 1).padStart(2, "0")}
          </p>
          <h3 class="text-lg font-black leading-7 text-[var(--dw-ink)]">{step.title}</h3>
          <p class="text-sm font-medium leading-7 text-[var(--dw-ink-soft)]">{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
