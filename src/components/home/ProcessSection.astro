---
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="bg-[oklch(0.18_0.025_260)] px-5 py-16 text-white md:py-24">
  <div class="mx-auto grid max-w-[1320px] gap-10 lg:grid-cols-[0.34fr_0.66fr]">
    <h2 class="text-balance font-display text-4xl font-semibold leading-tight md:text-5xl">{content.processTitle}</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        content.process.map((step, index) => (
          <article class="border-t border-white/18 py-6">
            <p class="text-sm font-black text-[oklch(0.78_0.1_205)]">{String(index + 1).padStart(2, "0")}</p>
            <h3 class="mt-5 font-display text-2xl font-semibold">{step.title}</h3>
            <p class="mt-3 text-sm font-semibold leading-7 text-white/72">{step.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
