---
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="px-5 py-16 md:py-24" id="cases">
  <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr]">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{content.projectTypesTitle}</h2>
      <p class="mt-5 max-w-md text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_260)]">{content.projectTypesLead}</p>
    </div>
    <div class="dw-reveal-stagger border-t border-[var(--dw-line)]">
      {
        content.projectTypes.map((project) => (
          <article class="grid gap-3 border-b border-[var(--dw-line)] py-6 md:grid-cols-[180px_1fr]">
            <h3 class="font-impact text-lg font-extrabold text-[oklch(0.2_0.035_260)]">{project.title}</h3>
            <p class="text-sm font-semibold leading-7 text-[oklch(0.48_0.04_260)]">{project.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
