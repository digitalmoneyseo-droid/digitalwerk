---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="bg-white px-5 py-20 md:py-28">
  <div class="dw-container grid gap-12 lg:grid-cols-[0.5fr_0.5fr] lg:items-center">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-black leading-[1.04] tracking-[-0.03em] text-[var(--dw-ink)] md:text-6xl">
        {content.whyTitle}
      </h2>
      <p class="mt-6 max-w-xl text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
        {content.whyLead}
      </p>
    </div>

    <div class="dw-reveal-stagger border-y border-[var(--dw-card-border)]">
      {content.whyItems.map((item) => (
        <article class="grid gap-4 border-b border-[var(--dw-card-border)] py-6 last:border-b-0 sm:grid-cols-[2.75rem_1fr]">
          <span class="grid h-11 w-11 place-items-center rounded-md bg-[oklch(0.94_0.05_250)] text-[var(--dw-accent-strong)]">
            <Icon name="BriefcaseBusiness" size={18} />
          </span>
          <div>
            <h3 class="text-xl font-black leading-7 tracking-[-0.015em] text-[var(--dw-ink)]">{item.title}</h3>
            <p class="mt-2 text-sm font-medium leading-7 text-[var(--dw-ink-soft)]">{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
