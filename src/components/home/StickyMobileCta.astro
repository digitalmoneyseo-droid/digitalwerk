---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";
---

<div class="fixed inset-x-0 bottom-0 z-40 border-t border-[var(--dw-card-border)] bg-white/94 p-3 shadow-[0_-10px_30px_oklch(0.18_0.03_260_/_0.10)] backdrop-blur md:hidden">
  <a href="/kontakt" class="group inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white">
    {siteContent.navigation.ctaLabel}
    <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
  </a>
</div>
