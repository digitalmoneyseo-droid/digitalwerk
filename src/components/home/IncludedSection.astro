---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
const icons = ["Layers", "Palette", "Monitor", "SearchCheck", "Mail", "Target"] as const;
---

<section class="bg-[var(--dw-surface-warm)] px-5 py-20 md:py-28">
  <div class="dw-container grid gap-12 lg:grid-cols-[0.36fr_0.64fr] lg:items-start">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">
        {content.includedTitle}
      </h2>
      <p class="mt-5 max-w-md text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
        {content.includedLead}
      </p>
    </div>

    <div class="dw-reveal-stagger grid gap-3 sm:grid-cols-2">
      {content.includedItems.map((item, index) => (
        <article class="grid gap-4 rounded-lg border border-[var(--dw-card-border)] bg-white/[0.78] p-5">
          <span class="grid h-10 w-10 place-items-center rounded-md bg-[var(--dw-dark)] text-white">
            <Icon name={icons[index] ?? "Layers"} size={18} />
          </span>
          <div>
            <h3 class="text-base font-black leading-6 text-[var(--dw-ink)]">{item.title}</h3>
            <p class="mt-2 text-sm font-medium leading-6 text-[var(--dw-ink-soft)]">{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
