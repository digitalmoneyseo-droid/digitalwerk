---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const plans = siteContent.pricingCards;
---

<section class="bg-white px-5 py-20 md:py-28" id="preise">
  <div class="dw-container">
    <div class="dw-reveal mx-auto max-w-3xl text-center">
      <h2 class="text-balance break-words font-display text-4xl font-black leading-[1.05] tracking-[-0.025em] text-[var(--dw-ink)] sm:text-5xl md:text-6xl">
        Klare Einstiegspakete
      </h2>
      <p class="mt-5 text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
        Transparente Richtwerte für Websites, Relaunches und laufende Betreuung. Der konkrete Umfang entsteht nach dem Erstgespräch.
      </p>
    </div>

    <div class="dw-reveal-stagger mt-12 grid gap-5 lg:grid-cols-3 lg:items-stretch">
      {plans.map((plan) => (
        <article
          class={`relative flex min-h-[560px] flex-col rounded-lg border p-6 ${
            plan.featured
              ? "border-[oklch(0.22_0.045_255)] bg-[var(--dw-dark)] text-white lg:-mt-5"
              : "border-[var(--dw-card-border)] bg-[var(--dw-surface)] text-[var(--dw-ink)]"
          }`}
        >
          {plan.featured && (
            <span class="absolute right-5 top-5 rounded-full bg-white px-3 py-1 text-xs font-black text-[var(--dw-dark)]">
              Häufigster Einstieg
            </span>
          )}
          <p class={`text-sm font-black ${plan.featured ? "pr-36 text-white/82" : "text-[var(--dw-accent-strong)]"}`}>{plan.name}</p>
          <p class={`mt-4 text-base font-medium leading-7 ${plan.featured ? "text-white/72" : "text-[var(--dw-ink-soft)]"}`}>{plan.lead}</p>
          <p class="mt-8 font-display text-4xl font-black leading-none tracking-[-0.035em] md:text-5xl">{plan.price}</p>
          <div class={`my-7 h-px ${plan.featured ? "bg-white/14" : "bg-[var(--dw-card-border)]"}`}></div>
          <ul class="grid gap-3">
            {plan.features.map((feature) => (
              <li class={`flex items-start gap-3 text-sm font-medium leading-6 ${plan.featured ? "text-white/84" : "text-[var(--dw-ink-soft)]"}`}>
                <Icon name="CircleCheckBig" size={17} class={`mt-1 shrink-0 ${plan.featured ? "text-[oklch(0.78_0.12_155)]" : "text-[var(--dw-green)]"}`} />
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <a
            href="/kontakt"
            class={`mt-auto inline-flex min-h-12 items-center justify-center rounded-full px-5 py-3 text-sm font-black transition hover:-translate-y-0.5 active:translate-y-0 ${
              plan.featured
                ? "bg-white text-[var(--dw-dark)]"
                : "border border-[oklch(0.78_0.04_250)] bg-white text-[var(--dw-ink)] hover:border-[var(--dw-accent)]"
            }`}
          >
            Plan anfragen
          </a>
        </article>
      ))}
    </div>

    <p class="mx-auto mt-6 max-w-3xl text-center text-sm font-medium leading-6 text-[var(--dw-muted)]">
      Richtwerte zzgl. ggf. Media-Budget, Tools oder Hosting. Nach dem Gespräch ist klar, was wirklich gebraucht wird.
    </p>
  </div>
</section>
