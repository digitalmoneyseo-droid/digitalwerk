---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";
import type { IconName } from "../../lib/navigation";

const content = siteContent.home.one;
const serviceIcons: IconName[] = ["Monitor", "Search", "Megaphone", "Sparkles"];
const colorClasses = [
  "bg-[oklch(0.94_0.05_250)] text-[oklch(0.42_0.14_250)]",
  "bg-[oklch(0.94_0.06_155)] text-[oklch(0.39_0.13_155)]",
  "bg-[oklch(0.94_0.07_62)] text-[oklch(0.48_0.15_62)]",
  "bg-[oklch(0.94_0.06_295)] text-[oklch(0.43_0.14_295)]",
];
---

<section class="bg-white px-5 py-20 md:py-28" id="leistungen">
  <div class="dw-container grid gap-12 lg:grid-cols-[0.37fr_0.63fr] lg:items-start">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-black leading-[1.06] tracking-[-0.025em] text-[var(--dw-ink)] md:text-5xl">
        {content.serviceRunwayTitle}
      </h2>
      <p class="mt-5 max-w-md text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)]">
        {content.serviceRunwayLead}
      </p>

      <div class="mt-8 border-y border-[var(--dw-card-border)]">
        {content.serviceFlow.map((step) => (
          <div class="grid gap-2 border-b border-[var(--dw-card-border)] py-5 last:border-b-0 sm:grid-cols-[6rem_1fr]">
            <p class="font-utility text-xs font-bold uppercase tracking-[0.12em] text-[var(--dw-accent-strong)]">{step.label}</p>
            <div>
              <p class="text-sm font-black leading-6 text-[var(--dw-ink)]">{step.title}</p>
              <p class="mt-1 text-sm font-medium leading-6 text-[var(--dw-ink-soft)]">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="dw-reveal-stagger grid gap-4 md:grid-cols-2">
      {content.services.map((service, index) => (
        <a
          href={service.href}
          class="group grid min-h-[220px] content-between rounded-lg border border-[var(--dw-card-border)] bg-[var(--dw-surface)] p-6 transition hover:-translate-y-0.5 hover:border-[oklch(0.72_0.05_250)] hover:shadow-[var(--dw-card-shadow-tight)] active:translate-y-0"
        >
          <span class="flex items-start justify-between gap-4">
            <span class={`grid h-11 w-11 place-items-center rounded-md ${colorClasses[index] ?? colorClasses[0]}`}>
              <Icon name={serviceIcons[index] ?? "Monitor"} size={19} />
            </span>
            <Icon name="ArrowRight" size={17} class="text-[var(--dw-accent-strong)] transition-transform group-hover:translate-x-1" />
          </span>
          <span class="mt-8 block">
            <span class="block font-display text-2xl font-black leading-tight tracking-[-0.02em] text-[var(--dw-ink)]">{service.title}</span>
            <span class="mt-3 block text-sm font-medium leading-6 text-[var(--dw-ink-soft)]">{service.text}</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
