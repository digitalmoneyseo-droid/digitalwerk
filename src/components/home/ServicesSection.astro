---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";
import type { IconName } from "../../lib/navigation";

const content = siteContent.home.one;
const serviceIcons: IconName[] = ["Monitor", "Search", "Megaphone", "Share2", "Palette", "Sparkles"];
---

<section class="bg-white px-5 py-16 md:py-24" id="leistungen">
  <div class="mx-auto grid max-w-[1180px] gap-10 lg:grid-cols-[0.42fr_0.58fr] lg:items-start">
    <div class="dw-reveal">
      <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-5xl">{content.serviceRunwayTitle}</h2>
      <p class="mt-5 max-w-md text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_260)]">{content.serviceRunwayLead}</p>
    </div>
    <div class="dw-reveal-stagger border-t border-[var(--dw-line)]">
      {
        content.services.map((service, index) => (
          <a
            href={service.href}
            class="group grid gap-4 border-b border-[var(--dw-line)] py-6 transition hover:bg-[oklch(0.985_0.008_245)] sm:grid-cols-[54px_1fr_auto] sm:items-center"
          >
            <span class="grid h-11 w-11 place-items-center rounded-[12px] bg-[oklch(0.94_0.032_245)] text-[oklch(0.5_0.14_245)]">
              <Icon name={serviceIcons[index] ?? "Monitor"} size={19} />
            </span>
            <span>
              <span class="block font-impact text-lg font-extrabold text-[oklch(0.2_0.035_260)]">{service.title}</span>
              <span class="mt-1 block text-sm font-semibold leading-6 text-[oklch(0.5_0.04_260)]">{service.text}</span>
            </span>
            <Icon name="ArrowRight" size={17} class="hidden text-[oklch(0.58_0.14_245)] transition-transform group-hover:translate-x-1 sm:block" />
          </a>
        ))
      }
    </div>
  </div>
</section>
