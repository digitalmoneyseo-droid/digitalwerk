---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="px-5 py-20 md:py-28" id="kontakt">
  <div class="mx-auto max-w-[900px] text-center">
    <h2 class="text-balance font-display text-4xl font-semibold leading-none text-[oklch(0.22_0.04_260)] md:text-6xl">{content.finalCtaTitle}</h2>
    <p class="mx-auto mt-6 max-w-2xl text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_260)]">{content.finalCtaLead}</p>
    <a
      href="/kontakt"
      class="group mt-9 inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-[oklch(0.14_0.025_260)] px-5 py-3 text-sm font-black text-white shadow-[0_10px_24px_oklch(0.18_0.035_260/0.14)] transition hover:-translate-y-0.5 hover:bg-[oklch(0.28_0.08_250)] active:translate-y-0"
    >
      Projekt besprechen
      <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
    </a>
  </div>
</section>
