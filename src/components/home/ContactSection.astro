---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="px-5 py-20 md:py-28" id="kontakt">
  <div class="mx-auto max-w-[900px] text-center">
    <h2 class="text-balance font-display text-4xl font-extrabold leading-[1.03] text-[oklch(0.22_0.04_260)] md:text-6xl">{content.finalCtaTitle}</h2>
    <p class="mx-auto mt-6 max-w-2xl text-pretty text-base font-semibold leading-8 text-[oklch(0.48_0.04_260)]">{content.finalCtaLead}</p>
    <a
      href="/kontakt"
      class="group mt-9 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-5 py-3 text-sm font-black text-white transition hover:-translate-y-0.5 hover:bg-[oklch(0.28_0.08_250)] active:translate-y-0"
    >
      {content.primaryCta}
      <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
    </a>
  </div>
</section>
