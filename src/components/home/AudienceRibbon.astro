---
const industries = ["Lokale Dienstleister", "B2B", "E-Commerce", "Praxen", "Kanzleien", "Handwerk"];
---

<section class="bg-white px-5 py-14" aria-label="Branchen">
  <div class="mx-auto max-w-[1180px]">
    <p class="text-center text-[12px] font-black uppercase tracking-[0.28em] text-[oklch(0.78_0.03_250)]">Für Unternehmen, die online klarer verkaufen wollen</p>
    <div class="dw-reveal-stagger mt-10 grid grid-cols-2 gap-x-8 gap-y-6 text-center sm:grid-cols-3 lg:grid-cols-6">
      {industries.map((item) => <span class="font-impact text-sm font-extrabold text-[oklch(0.64_0.03_260)]">{item}</span>)}
    </div>
  </div>
</section>
