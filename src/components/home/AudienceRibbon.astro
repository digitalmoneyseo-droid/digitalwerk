---
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
---

<section class="border-y border-[oklch(0.88_0.018_250)] bg-white px-5 py-6" aria-label="Zielgruppen">
  <div class="mx-auto flex max-w-[1320px] flex-wrap items-center justify-center gap-3 md:justify-between">
    {content.audienceLine.map((item) => <span class="rounded-full border border-[oklch(0.88_0.018_250)] bg-[oklch(0.98_0.008_250)] px-4 py-2 text-sm font-black text-[oklch(0.31_0.035_260)]">{item}</span>)}
  </div>
</section>
