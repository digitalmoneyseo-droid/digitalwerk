---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
const icons = ["Target", "Monitor", "CircleCheckBig"] as const;
---

<section class="px-5 py-12" aria-labelledby="trust-heading">
  <div class="dw-container">
    <div class="grid gap-8 border-y border-[var(--dw-card-border)] py-8 lg:grid-cols-[0.42fr_0.58fr] lg:items-center">
      <div>
        <p class="font-utility text-xs font-bold uppercase tracking-[0.12em] text-[var(--dw-accent-strong)]">
          {content.trustEyebrow}
        </p>
        <h2 id="trust-heading" class="mt-3 max-w-lg text-balance font-display text-3xl font-black leading-[1.08] tracking-[-0.025em] text-[var(--dw-ink)] md:text-4xl">
          {content.trustTitle}
        </h2>
      </div>

      <div class="dw-reveal-stagger grid gap-3 md:grid-cols-3">
        {content.trustItems.map((item, index) => (
          <article class="rounded-lg bg-white/[0.76] p-5 shadow-[var(--dw-card-shadow-tight)]">
            <span class="grid h-10 w-10 place-items-center rounded-md bg-[oklch(0.94_0.035_250)] text-[var(--dw-accent-strong)]">
              <Icon name={icons[index] ?? "Target"} size={18} />
            </span>
            <h3 class="mt-5 text-base font-black leading-6 text-[var(--dw-ink)]">{item.title}</h3>
            <p class="mt-2 text-sm font-medium leading-6 text-[var(--dw-ink-soft)]">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
