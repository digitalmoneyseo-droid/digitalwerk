---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
const metricItems = [
  ["01", "Angebot klären"],
  ["02", "Sichtbarkeit ordnen"],
  ["03", "Anfragen führen"],
] as const;
const signalSteps = ["Website", "Suche", "Ads", "Anfrage"];
---

<section class="relative overflow-hidden px-5 pb-16 pt-32 md:pb-24 md:pt-40">
  <div class="dw-signal-field absolute inset-0" aria-hidden="true"></div>
  <div class="dw-page-spanning-line absolute bottom-0 left-0 right-0" aria-hidden="true"></div>
  <div class="relative mx-auto grid max-w-[1320px] gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="page-rise max-w-[720px]">
      <p class="mb-5 inline-flex rounded-full border border-[oklch(0.82_0.03_245)] bg-white/72 px-4 py-2 text-sm font-black text-[oklch(0.32_0.075_245)]">
        {content.heroBadge}
      </p>
      <h1 class="text-balance font-display text-5xl font-semibold leading-[0.98] text-[oklch(0.2_0.035_260)] md:text-7xl">
        Websites und Marketing, die aus Besuchern <span class="font-editorial font-semibold italic text-[oklch(0.44_0.13_245)]">echte Anfragen</span> machen.
      </h1>
      <p class="mt-7 max-w-2xl text-pretty text-lg font-semibold leading-8 text-[oklch(0.35_0.04_260)]">{content.lead}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="/kontakt"
          class="group inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[oklch(0.18_0.025_260)] px-5 py-3 text-sm font-black text-white shadow-[0_12px_28px_oklch(0.18_0.035_260/0.18)] transition hover:-translate-y-0.5 hover:bg-[oklch(0.33_0.095_250)] active:translate-y-0"
        >
          {content.primaryCta}
          <Icon name="ArrowRight" size={17} class="transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="/leistungen/webdesign"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-[oklch(0.72_0.03_260)] bg-white px-5 py-3 text-sm font-black text-[oklch(0.2_0.03_260)] transition hover:-translate-y-0.5 hover:border-[oklch(0.44_0.12_245)] hover:bg-[oklch(0.975_0.012_250)] active:translate-y-0"
        >
          {content.secondaryCta}
        </a>
      </div>
      <dl class="mt-9 grid max-w-2xl grid-cols-3 gap-3 border-y border-[oklch(0.82_0.024_250)] py-4">
        {
          metricItems.map(([value, label]) => (
            <div>
              <dt class="font-utility text-xs font-bold text-[oklch(0.45_0.12_245)]">{value}</dt>
              <dd class="mt-1 text-sm font-black leading-5 text-[oklch(0.24_0.035_260)]">{label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="dw-hero-cards relative mx-auto h-[430px] w-full max-w-[660px] md:h-[520px]" aria-label="Website-Check Vorschau">
      <div class="absolute inset-0 overflow-hidden rounded-[28px] border border-[oklch(0.82_0.024_250)] bg-white shadow-[0_24px_70px_oklch(0.18_0.035_260/0.13)]">
        <img src="/images/signal-atlas.png" alt="" class="h-full w-full object-cover opacity-90" loading="eager" decoding="async" />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,white_0%,rgb(255_255_255/0.82)_24%,transparent_62%),linear-gradient(0deg,rgb(255_255_255/0.76)_0%,transparent_36%)]"></div>
        <div class="absolute left-5 top-5 rounded-full border border-[oklch(0.78_0.03_245)] bg-white/88 px-3 py-1 text-xs font-black text-[oklch(0.34_0.09_245)] shadow-sm backdrop-blur">
          Digitalwerk Signalmap
        </div>
      </div>

      <div class="dw-card-rise absolute left-[7%] top-[24%] w-[74%] rounded-2xl border border-[oklch(0.84_0.022_250)] bg-white/94 p-5 shadow-[0_12px_34px_oklch(0.24_0.04_250/0.12)] backdrop-blur md:p-6">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-[oklch(0.94_0.045_250)] text-[oklch(0.48_0.16_250)]">
              <Icon name="Monitor" size={20} />
            </span>
            <div>
              <p class="text-sm font-black text-[oklch(0.31_0.035_260)]">Website-Check</p>
              <p class="text-xs font-bold text-[oklch(0.48_0.035_260)]">Struktur, SEO und Anfrageweg</p>
            </div>
          </div>
          <span class="rounded-full bg-[oklch(0.94_0.055_145)] px-3 py-1 text-xs font-black text-[oklch(0.43_0.14_145)]">Klar</span>
        </div>
        <div class="mt-7 grid grid-cols-4 gap-2 text-center text-[10px] font-black uppercase text-[oklch(0.42_0.045_260)]">
          {signalSteps.map((item) => <span class="rounded-lg border border-[oklch(0.87_0.024_250)] bg-[oklch(0.98_0.008_250)] px-2 py-2">{item}</span>)}
        </div>
        <div class="mt-4 h-28 overflow-hidden rounded-xl bg-[linear-gradient(180deg,transparent_0_68%,oklch(0.94_0.038_245)_68%)]">
          <svg viewBox="0 0 420 130" class="h-full w-full" role="img" aria-label="Ruhige Liniengrafik zur Website-Entwicklung">
            <path d="M0 102 C 76 88, 122 88, 196 68 S 328 46, 420 30" fill="none" stroke="oklch(0.69 0.11 245)" stroke-width="4" stroke-linecap="round"></path>
            <path d="M0 116 C 90 106, 144 104, 226 82 S 336 66, 420 48" fill="none" stroke="oklch(0.82 0.08 205)" stroke-width="2" stroke-linecap="round"></path>
          </svg>
        </div>
      </div>

      <a
        href="/kontakt"
        class="dw-card-rise absolute right-[3%] top-[10%] block w-[245px] rounded-2xl border border-[oklch(0.82_0.024_250)] bg-white/95 p-4 text-left shadow-[0_12px_32px_oklch(0.24_0.04_250/0.12)] backdrop-blur transition hover:border-[oklch(0.58_0.12_245)] active:scale-[0.99]"
        style="animation-delay: 120ms"
      >
        <span class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-[oklch(0.94_0.05_150)] text-[oklch(0.45_0.15_150)]">
            <Icon name="CircleCheckBig" size={19} />
          </span>
          <span>
            <span class="block font-display text-xl font-semibold text-[oklch(0.24_0.035_260)]">Erstberatung</span>
            <span class="mt-1 block text-xs font-bold text-[oklch(0.48_0.035_260)]">nächsten Schritt klären</span>
          </span>
        </span>
      </a>

      <a
        href="/leistungen/local-seo"
        class="dw-card-rise absolute bottom-[16%] left-0 block w-[210px] rounded-2xl border border-[oklch(0.82_0.024_250)] bg-white/95 p-4 text-left shadow-[0_12px_32px_oklch(0.24_0.04_250/0.12)] backdrop-blur transition hover:border-[oklch(0.58_0.12_245)] active:scale-[0.99]"
        style="animation-delay: 220ms"
      >
        <span class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-[oklch(0.96_0.045_70)] text-[oklch(0.58_0.14_70)]">
            <Icon name="Search" size={19} />
          </span>
          <span>
            <span class="block font-display text-xl font-semibold text-[oklch(0.24_0.035_260)]">SEO-Basis</span>
            <span class="mt-1 block text-xs font-bold text-[oklch(0.48_0.035_260)]">Google-Sichtbarkeit prüfen</span>
          </span>
        </span>
      </a>
    </div>
  </div>
</section>
