---
import Icon from "../Icon.astro";
import { siteContent } from "../../data/siteContent";

const content = siteContent.home.one;
const [titleStart, titleEnd = ""] = content.title.split(content.highlight);
---

<section class="relative isolate overflow-hidden px-5 pb-18 pt-32 md:pb-24 md:pt-40">
  <div class="dw-noise absolute inset-0 -z-10" aria-hidden="true"></div>

  <div class="dw-container grid gap-12 lg:grid-cols-[minmax(0,0.56fr)_minmax(360px,0.44fr)] lg:items-center">
    <div class="page-rise">
      <p class="dw-kicker">{content.heroBadge}</p>

      <h1 class="mt-6 max-w-4xl text-balance font-display text-5xl font-black leading-[1.01] tracking-[-0.03em] text-[var(--dw-ink)] md:text-6xl xl:text-7xl">
        {titleStart}<span class="text-[var(--dw-accent-strong)]">{content.highlight}</span>{titleEnd}
      </h1>

      <p class="mt-7 max-w-2xl text-pretty text-base font-medium leading-8 text-[var(--dw-ink-soft)] md:text-lg">
        {content.lead}
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a
          href="/kontakt"
          class="group inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[var(--dw-dark)] px-6 py-3 text-sm font-black text-white transition hover:-translate-y-0.5 hover:bg-[oklch(0.25_0.06_255)] active:translate-y-0"
        >
          {content.primaryCta}
          <Icon name="ArrowRight" size={16} class="transition-transform group-hover:translate-x-0.5" />
        </a>

        <a
          href="#leistungen"
          class="inline-flex min-h-12 items-center justify-center rounded-full border border-[oklch(0.78_0.04_250)] bg-white/82 px-6 py-3 text-sm font-black text-[var(--dw-ink)] transition hover:-translate-y-0.5 hover:bg-white active:translate-y-0"
        >
          {content.secondaryCta}
        </a>
      </div>

      <div class="mt-7 flex flex-wrap gap-2.5" aria-label="Projektvorteile">
        {content.heroProof.map((item) => (
          <span class="inline-flex min-h-10 items-center gap-2 rounded-full border border-[var(--dw-card-border)] bg-white/[0.76] px-3.5 py-2 text-sm font-bold leading-5 text-[var(--dw-ink-soft)]">
            <Icon name="CircleCheckBig" size={15} class="shrink-0 text-[var(--dw-green)]" />
            {item}
          </span>
        ))}
      </div>

      <p class="mt-5 max-w-xl text-sm font-medium leading-6 text-[var(--dw-muted)]">
        {content.audienceLine}
      </p>
    </div>

    <aside class="dw-panel-enter relative" aria-label={content.heroMetricCard.title}>
      <div class="rounded-lg border border-[oklch(0.74_0.05_250)] bg-[var(--dw-dark)] p-3 text-white shadow-[var(--dw-card-shadow)]">
        <div class="rounded-md bg-white p-4 text-[var(--dw-ink)]">
          <div class="flex items-center justify-between gap-4 border-b border-[var(--dw-card-border)] pb-4">
            <div>
              <p class="font-utility text-xs font-bold uppercase tracking-[0.12em] text-[var(--dw-accent-strong)]">
                {content.heroMetricCard.eyebrow}
              </p>
              <h2 class="mt-2 max-w-sm text-balance font-display text-2xl font-black leading-[1.06] tracking-[-0.025em]">
                {content.heroMetricCard.title}
              </h2>
            </div>
            <span class="hidden rounded-full bg-[oklch(0.94_0.07_155)] px-3 py-1 text-xs font-black text-[oklch(0.35_0.11_155)] sm:inline-flex">
              Live vor Launch
            </span>
          </div>

          <div class="grid gap-0">
            {content.heroMetricCard.items.map(([number, text]) => (
              <div class="grid grid-cols-[3.25rem_1fr] items-center border-b border-[var(--dw-card-border)] py-4">
                <span class="font-display text-2xl font-black tracking-[-0.03em] text-[var(--dw-accent-strong)]">{number}</span>
                <p class="text-sm font-bold leading-6 text-[var(--dw-ink)]">{text}</p>
              </div>
            ))}
          </div>

          <div class="mt-4 grid gap-3 rounded-md bg-[oklch(0.965_0.024_82)] p-4">
            <div class="flex items-center justify-between gap-4">
              <span class="text-xs font-black uppercase tracking-[0.12em] text-[var(--dw-muted)]">Anfrageweg</span>
              <span class="rounded-full bg-[var(--dw-dark)] px-3 py-1 text-xs font-black text-white">prüfbar</span>
            </div>
            <div class="grid grid-cols-[1fr_auto_1fr_auto_1fr] items-center gap-2 text-center text-xs font-black text-[var(--dw-ink-soft)]">
              <span>Besuch</span>
              <span class="h-px bg-[var(--dw-line)]"></span>
              <span>Vertrauen</span>
              <span class="h-px bg-[var(--dw-line)]"></span>
              <span>Kontakt</span>
            </div>
            <p class="text-sm font-bold leading-6 text-[var(--dw-ink-soft)]">{content.heroMetricCard.result}</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>
