---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteContent } from "../data/siteContent";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = `${siteContent.brand.name} - ${siteContent.brand.shortDescriptor}`,
  description = siteContent.meta.defaultDescription,
} = Astro.props;
const siteUrl = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL("/og-image.png", siteUrl).toString();
const siteOrigin = new URL(siteUrl).origin;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0c1324" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteContent.brand.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.add("dw-can-reveal");
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      name: siteContent.brand.name,
      description,
      areaServed: "Deutschland",
      email: siteContent.brand.email,
      url: siteOrigin,
      sameAs: [],
      serviceType: [
        "Webdesign",
        "Suchmaschinenoptimierung",
        "Paid Advertising",
        "KI-Automatisierung",
      ],
    })}></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <Header />
    <slot />
    <Footer />
    <script>
      const revealItems = document.querySelectorAll<HTMLElement>(".dw-reveal, .dw-reveal-stagger");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -12% 0px", threshold: 0.14 },
        );

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
